# ============================
# connect:seoul Server — 환경변수 예시
# 실제 값은 EC2 서버에 직접 설정. 이 파일은 커밋 가능.
# ============================

NODE_ENV=production
PORT=3000

# 데이터베이스
DB_PATH=./data/way_game.sqlite

# JWT
JWT_SECRET=<강력한_랜덤_문자열>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<강력한_랜덤_문자열>
JWT_REFRESH_EXPIRES_IN=7d

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Rate Limit
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# 비밀번호 재설정 만료 (분)
PASSWORD_RESET_EXPIRY_MINUTES=30

# 로그
LOG_LEVEL=info

# 어드민 패널
ADMIN_SECRET=<강력한_랜덤_문자열>

# Gemini AI
GEMINI_API_KEY=<Google_Cloud_Console에서_발급>

# AWS S3 백업 (EC2 IAM Role 사용 시 ACCESS_KEY 생략 가능)
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=projects-data
S3_DB_KEY=way-server/way_game.sqlite
S3_BACKUP_INTERVAL_MS=600000
# AWS_ACCESS_KEY_ID=<IAM_Role_없을_때만>
# AWS_SECRET_ACCESS_KEY=<IAM_Role_없을_때만>
